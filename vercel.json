{
  "functions": {
    "src/pages/api/v1/[[...path]].ts": {
      "maxDuration": 30,
      "memory": 1024
    },
    "src/pages/api/v1/auth/login.ts": {
      "maxDuration": 30,
      "memory": 1024
    },
    "src/pages/api/uploads/[[...path]].ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/uploads/(.*)",
      "destination": "/api/uploads/$1"
    }
  ]
}
