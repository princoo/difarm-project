{
  "functions": {
    "src/pages/api/v1/[[...path]].ts": {
      "maxDuration": 30,
      "memory": 1024
    },
    "src/pages/api/uploads/[[...path]].ts": {
      "maxDuration": 30
    }
  },
  "services": {
    "frontend": {
        "root": ".",
        "framework": "nextjs"
    },
    "backend": {
        "root": "backend"
    }
},
  "rewrites": [
    {
      "source": "/uploads/(.*)",
      "destination": "/api/uploads/$1"
    },
    {
      "source": "/api/backend(/.*)?",
      "destination": {
          "type": "service",
          "service": "backend"
      }
  },
  {
      "source": "/(.*)",
      "destination": {
          "type": "service",
          "service": "frontend"
      }
  }
  ]
}
